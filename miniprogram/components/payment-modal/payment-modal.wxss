/* components/payment-modal/payment-modal.wxss */
.payment-modal {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  justify-content: center;
  align-items: center;
}

.payment-content {
  background-color: white;
  border-radius: 24rpx;
  padding: 60rpx;
  width: 600rpx;
  max-width: 90%;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.3);
  position: relative;
}

.close-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #999;
  border-radius: 50%;
  transition: all 0.3s;
}

.close-btn:active {
  background-color: #f5f5f5;
  color: #333;
}

.payment-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.payment-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1f3a;
  margin-bottom: 20rpx;
}

.payment-amount {
  font-size: 64rpx;
  font-weight: bold;
  color: #d32f2f;
  margin: 30rpx 0;
}

.payment-desc {
  font-size: 28rpx;
  color: #666;
}

.payment-method {
  display: flex;
  align-items: center;
  gap: 30rpx;
  padding: 30rpx;
  border: 4rpx solid #4CAF50;
  border-radius: 16rpx;
  background-color: #f1f8f4;
  margin-bottom: 40rpx;
}

.payment-method-icon {
  width: 80rpx;
  height: 80rpx;
  background-color: #07c160;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 48rpx;
  font-weight: bold;
}

.payment-method-text {
  flex: 1;
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1f3a;
}

.qrcode-container {
  text-align: center;
  padding: 40rpx;
  background-color: #f9f9f9;
  border-radius: 16rpx;
  margin: 40rpx 0;
}

.qrcode-image {
  width: 400rpx;
  height: 400rpx;
  border: 4rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 20rpx;
  background-color: white;
}

.qrcode-tip {
  margin-top: 30rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
}

.qrcode-status {
  margin-top: 20rpx;
  font-size: 28rpx;
  font-weight: bold;
  color: #07c160;
}

.payment-loading,
.payment-success {
  text-align: center;
  padding: 40rpx;
  font-size: 32rpx;
  color: #666;
}

.payment-success {
  color: #4CAF50;
  font-size: 40rpx;
  font-weight: bold;
}

.payment-error {
  text-align: center;
  padding: 30rpx;
  color: #d32f2f;
  background-color: #ffebee;
  border-radius: 12rpx;
  margin: 30rpx 0;
  font-size: 28rpx;
}

.payment-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.payment-btn {
  flex: 1;
  padding: 24rpx 48rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.payment-btn-primary {
  background-color: #07c160;
  color: white;
}

.payment-btn-primary:active {
  background-color: #06ad56;
}

.payment-btn-primary[disabled] {
  opacity: 0.6;
}

.payment-btn-cancel {
  background-color: #f5f5f5;
  color: #666;
}

.payment-btn-cancel:active {
  background-color: #e0e0e0;
}
