/* pages/admin/admin.wxss */
.container {
  padding: 40rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1a1f3a;
  text-align: center;
  margin-bottom: 40rpx;
}

.info-text {
  text-align: center;
  color: #666;
  font-size: 28rpx;
  margin-bottom: 40rpx;
}

.info-item {
  margin-bottom: 30rpx;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.info-value {
  font-size: 32rpx;
  color: #1a1f3a;
  font-weight: 600;
  word-break: break-all;
}

.btn-secondary {
  margin-top: 20rpx;
  width: 100%;
}
